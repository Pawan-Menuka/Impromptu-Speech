# --- Database (Phase 0) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth: Clerk (Phase 0) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
