# Committed template — copy to .env.local and fill in real values.
# `.env.local` is gitignored; this file documents the required variables.

# --- Database (Phase 0) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth: Clerk (Phase 0) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/dashboard"

# --- Transcription: AssemblyAI (Phase 3) ---
ASSEMBLYAI_API_KEY="aai_xxx"

# --- LLM rating provider selector (Phase 4) ---
# "anthropic" (default, production) or "gemini" (free-tier testing).
RATING_PROVIDER="anthropic"

# --- LLM: Anthropic / Claude (Phase 4) ---
ANTHROPIC_API_KEY="sk-ant-xxx"

# --- LLM (alternative, testing): Google Gemini ---
# Get a free key at https://aistudio.google.com → "Get API key" (starts with AIza).
GEMINI_API_KEY="AIza-xxx"

# --- Audio storage: Cloudflare R2 (Phase 2) ---
R2_ACCOUNT_ID="xxx"
R2_ACCESS_KEY_ID="xxx"
R2_SECRET_ACCESS_KEY="xxx"
R2_BUCKET="impromptu-speech-audio"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# --- Landing frame sequence (optional) ---
# Where the 178 landing frames are served from. Leave unset to use the local
# public/frames folder. In production point it at R2/CDN so those ~178 requests
# per visit don't hit Vercel. Upload with `npm run frames:upload`.
# NEXT_PUBLIC_FRAME_BASE_URL="https://pub-xxx.r2.dev/frames"

# --- Rate limiting: Upstash Redis (optional but recommended in prod) ---
# Shared store so the cost guards on the paid routes hold across Vercel's
# serverless instances. Without these, rate limiting falls back to per-instance
# in-memory counting (fine for local dev; weaker under real load). Create a free
# database at https://console.upstash.com (Redis) and copy its REST creds.
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

